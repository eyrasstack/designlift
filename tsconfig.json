    "target": "ES2020",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "node",
    "esModuleInterop": true
